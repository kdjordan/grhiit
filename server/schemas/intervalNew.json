{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://our.company.com/jobNew.schema.json",
  "type": "object",
  "properties": {
    "workout_id": {
      "type": "integer"
    },
    "sequence_id": {
      "type": "integer"
    },
    "sort_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50
    },
    "movement_name": {
      "type": "string",
      "minimum": 0,
      "minLength": 1,
      "maxLength": 30
    },
    "movement_abbrv": {
      "type": "string",
      "minimum": 0,
      "minLength": 1,
      "maxLength": 30
    },
    "work": {
      "type": "integer"
    },
    "rest": {
      "type": "integer"
    },
    "rounds": {
      "type": "integer"
    }
  },
  "additionalProperties": false,
  "required": [
    "workout_id",
    "sequence_id",
    "movement_name",
    "work",
    "rest",
    "rounds"
  ]
}
