{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "http://our.company.com/jobNew.schema.json",
  "type": "object",
  "properties": {
    "workoutName": {
      "type": "string"
    },
    "workoutDesc": {
      "type": "string"
    },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "movementName": {
            "type": "string"
          },
          "movementAbbrv": {
            "type": "string"
          },
          "work": {
            "type": "number"
          },
          "rest": {
            "type": "number"
          },
          "rounds": {
            "type": "number"
          },
          "id": {
            "type": "string",
            "format": "uuid"
          }
        },
        "required": ["movementName", "movementAbbrv", "work", "rest", "rounds", "id"]
      }
    }
  },
  "required": ["workoutName", "workoutDesc", "data"]
}
